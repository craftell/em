{
  "name": "emviz",
  "version": "0.1.1",
  "description": "Interactive Event Modeling visualizer CLI.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/craftell/em"
  },
  "bin": {
    "emviz": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm --filter @emviz/parser build && pnpm --filter @emviz/graph build && pnpm --filter @emviz/validator build && pnpm --filter @emviz/app build && pnpm build",
    "start": "node dist/index.js .",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@emviz/graph": "workspace:*",
    "@emviz/parser": "workspace:*",
    "@emviz/validator": "workspace:*",
    "esbuild": "0.27.7",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
